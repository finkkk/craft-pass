# Only used with: docker compose --profile caddy up
# Use a domain name for automatic HTTPS, or :80 for local HTTP.
SITE_ADDRESS=:80

# Loopback port used by a reverse proxy installed on the Docker host.
APP_PORT=47821

# Must exactly match the public site origin. Separate multiple origins with commas.
# The default is for direct access without the optional Caddy profile.
CORS_ORIGINS=http://localhost:47821

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ADMIN_SESSION_TTL_HOURS=8

RCON_ENABLED=false
# Use host.docker.internal when Minecraft runs on the Docker host.
RCON_HOST=host.docker.internal
RCON_PORT=25575
RCON_PASSWORD=replace-with-a-strong-password
RCON_TIMEOUT_MS=5000
RCON_WHITELIST_ADD_COMMAND=whitelist add {minecraftId}
RCON_WHITELIST_RELOAD_COMMAND=

# Recommended for production. Generate with: openssl rand -base64 48
APP_SECRET=replace-with-at-least-32-random-characters
# Optional fixed first-run token. If omitted, read the generated token from app logs.
# SETUP_TOKEN=replace-with-at-least-16-random-characters
