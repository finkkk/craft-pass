generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ApplicationStatus {
  QUIZ_FAILED    @map("quiz_failed")
  PENDING_REVIEW @map("pending_review")
  REJECTED       @map("rejected")
  WHITELISTED    @map("whitelisted")
  RCON_FAILED    @map("rcon_failed")

  @@map("application_status")
}

enum AdminAction {
  LOGIN
  LOGOUT
  APPROVE_APPLICATION
  REJECT_APPLICATION
  RETRY_RCON
  RCON_FAILED
  UPDATE_APPLICATION
  DELETE_APPLICATION
  UPDATE_CONTENT
  UPDATE_LOGO

  @@map("admin_action")
}

enum RconAttemptStatus {
  PENDING
  SUCCEEDED
  FAILED

  @@map("rcon_attempt_status")
}

model Application {
  id                    String            @id @default(cuid())
  qqNumber              String            @map("qq_number")
  minecraftId           String            @map("minecraft_id")
  minecraftIdNormalized String            @map("minecraft_id_normalized")
  score                 Int
  passedQuiz            Boolean           @map("passed_quiz")
  status                ApplicationStatus
  agreementVersion      String            @map("agreement_version")
  signedAt              DateTime          @map("signed_at")
  reviewedAt            DateTime?         @map("reviewed_at")
  reviewerId            String?           @map("reviewer_id")
  rejectReason          String?           @map("reject_reason")
  ipAddress             String?           @map("ip_address")
  userAgent             String?           @map("user_agent")
  answersJson           Json              @map("answers_json")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  reviewer              Admin?            @relation("ApplicationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  adminLogs             AdminLog[]
  rconAttempts          RconAttempt[]

  @@index([status, createdAt])
  @@index([minecraftIdNormalized])
  @@index([qqNumber, createdAt])
  @@index([ipAddress, createdAt])
  @@map("applications")
}

model Admin {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String        @map("password_hash")
  role         String        @default("admin")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  reviews      Application[] @relation("ApplicationReviewer")
  adminLogs    AdminLog[]
  rconAttempts RconAttempt[]
  sessions     AdminSession[]

  @@map("admins")
}

model AdminSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique @map("token_hash")
  adminId    String   @map("admin_id")
  expiresAt  DateTime @map("expires_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, expiresAt])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AdminLog {
  id                  String       @id @default(cuid())
  adminId             String?      @map("admin_id")
  action              AdminAction
  targetApplicationId String?      @map("target_application_id")
  detail              Json?
  ipAddress           String?      @map("ip_address")
  createdAt           DateTime     @default(now()) @map("created_at")
  admin               Admin?       @relation(fields: [adminId], references: [id], onDelete: SetNull)
  targetApplication   Application? @relation(fields: [targetApplicationId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([targetApplicationId, createdAt])
  @@map("admin_logs")
}

model RconAttempt {
  id            String            @id @default(cuid())
  applicationId String            @map("application_id")
  adminId       String            @map("admin_id")
  status        RconAttemptStatus @default(PENDING)
  response      String?
  errorMessage  String?           @map("error_message")
  startedAt     DateTime          @default(now()) @map("started_at")
  finishedAt    DateTime?         @map("finished_at")
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  admin         Admin             @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([applicationId, startedAt])
  @@index([status, startedAt])
  @@map("rcon_attempts")
}
