{
  "name": "@craft-pass/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "test": "tsx tests/run.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "tsx scripts/ensure-database-file.ts && prisma migrate dev",
    "db:migrate:deploy": "tsx scripts/ensure-database-file.ts && prisma migrate deploy",
    "db:smoke": "tsx scripts/database-smoke.ts",
    "db:studio": "prisma studio",
    "admin:create": "tsx scripts/create-admin.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "rcon-srcds": "^2.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "prisma": "^7.8.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
