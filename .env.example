# All settings in this file are optional. Docker Compose starts without .env.

# Host loopback port used by an existing Nginx/Caddy reverse proxy.
APP_PORT=47821

# Public browser origins, separated with commas. Set this when using a domain.
# CORS_ORIGINS=https://apply.example.com

# Only used by the optional built-in Caddy profile.
# SITE_ADDRESS=apply.example.com

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ADMIN_SESSION_TTL_HOURS=8

# RCON is disabled by default and can be configured later in the setup wizard.
RCON_ENABLED=false
RCON_HOST=host.docker.internal
RCON_PORT=25575
RCON_PASSWORD=
RCON_TIMEOUT_MS=5000
RCON_WHITELIST_ADD_COMMAND=whitelist add {minecraftId}
RCON_WHITELIST_RELOAD_COMMAND=

# Leave these empty to generate secure persistent values automatically.
# APP_SECRET=
# SETUP_TOKEN=
