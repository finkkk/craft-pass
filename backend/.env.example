NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ADMIN_SESSION_TTL_HOURS=8

# SQLite 数据库文件；相对路径以 backend 目录为基准
DATABASE_URL="file:./data/craft-pass.db"

# 仅在运行 npm run admin:create 前临时填写，创建后请删除密码
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123

# 第七阶段接入 RCON 时填写；真实密码只写入 .env
RCON_ENABLED=false
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=replace-with-a-strong-password
RCON_TIMEOUT_MS=5000
RCON_WHITELIST_ADD_COMMAND=whitelist add {minecraftId}
# 留空表示加白名单后不额外执行 reload
RCON_WHITELIST_RELOAD_COMMAND=

# 可选：生产环境建议自行设置。未设置时会在 backend/data 生成本地密钥。
# APP_SECRET=至少32位随机字符串
# SETUP_TOKEN=至少16位的一次性部署令牌
